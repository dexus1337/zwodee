{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "windows-base",
            "hidden": true,
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_SYSTEM_NAME": "Windows",
                "CMAKE_CXX_FLAGS": "/W4 /EHsc /MP -DZWODEE_PLATFORM_WINDOWS"
            }
        },
        {
            "name": "windows-mingw-base",
            "hidden": true,
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc.exe",
                "CMAKE_CXX_COMPILER": "g++.exe",
                "CMAKE_SYSTEM_NAME": "Windows",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -DZWODEE_PLATFORM_WINDOWS"
            }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fPIC -DZWODEE_PLATFORM_LINUX"
            }
        },
        {
            "name": "windows-x64-debug",
            "displayName": "windows-x64-debug",
            "inherits": "windows-base",
            "architecture": { "value": "x64", "strategy": "external" },
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "windows-x64-release",
            "displayName": "windows-x64-release",
            "inherits": "windows-base",
            "architecture": { "value": "x64", "strategy": "external" },
            "cacheVariables": { 
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "windows-x64-rwdi",
            "displayName": "windows-x64-rwdi",
            "inherits": "windows-base",
            "architecture": { "value": "x64", "strategy": "external" },
            "cacheVariables": { 
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "windows-mingw-debug",
            "displayName": "windows-mingw-debug",
            "inherits": "windows-mingw-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "windows-mingw-release",
            "displayName": "windows-mingw-release",
            "inherits": "windows-mingw-base",
            "cacheVariables": { 
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "windows-mingw-rwdi",
            "displayName": "windows-mingw-rwdi",
            "inherits": "windows-mingw-base",
            "cacheVariables": { 
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "linux-x64-debug",
            "displayName": "linux-x64-debug",
            "inherits": "linux-base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "linux-x64-release",
            "displayName": "linux-x64-release",
            "inherits": "linux-base",
            "cacheVariables": { 
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "linux-x64-rwdi",
            "displayName": "linux-x64-rwdi",
            "inherits": "linux-base",
            "cacheVariables": { 
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        }
    ],
    "buildPresets": [
        { "name": "windows-x64-debug", "displayName": "windows-x64-debug", "configurePreset": "windows-x64-debug" },
        { "name": "windows-x64-release", "displayName": "windows-x64-release", "configurePreset": "windows-x64-release" },
        { "name": "windows-x64-rwdi", "displayName": "windows-x64-rwdi", "configurePreset": "windows-x64-rwdi" },
        { "name": "windows-mingw-debug", "displayName": "windows-mingw-debug", "configurePreset": "windows-mingw-debug" },
        { "name": "windows-mingw-release", "displayName": "windows-mingw-release", "configurePreset": "windows-mingw-release" },
        { "name": "windows-mingw-rwdi", "displayName": "windows-mingw-rwdi", "configurePreset": "windows-mingw-rwdi" },
        { "name": "linux-x64-debug", "displayName": "linux-x64-debug", "configurePreset": "linux-x64-debug" },
        { "name": "linux-x64-release", "displayName": "linux-x64-release", "configurePreset": "linux-x64-release" },
        { "name": "linux-x64-rwdi", "displayName": "linux-x64-rwdi", "configurePreset": "linux-x64-rwdi" }
    ],
    "testPresets": [
        {
            "name": "all",
            "configurePreset": "linux-x64-debug",
            "description": "Run all tests",
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": false,
                "jobs": 4
            },
            "output": {
                "outputOnFailure": true,
                "verbosity": "verbose"
            },
            "environment": {
                "ZWODEE_LOG_LEVEL": "DEBUG",
                "ASAN_OPTIONS": "detect_leaks=1"
            }
        }
    ]
}
